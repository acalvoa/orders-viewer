{
  "name": "repo",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach --parallel --interlaced run dev",
    "dev:frontend": "yarn workspace @repo/frontend run dev",
    "dev:backend": "yarn workspace @repo/backend run start:dev",
    "build": "yarn workspaces foreach --topological-dev run build",
    "start": "yarn workspaces foreach --parallel --interlaced run start"
  }
}
