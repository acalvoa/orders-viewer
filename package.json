{
  "name": "repo",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up directus -d && yarn workspaces foreach --all --parallel --interlaced --include '@repo/backend' --include '@repo/frontend' run dev",
    "dev:frontend": "yarn workspace @repo/frontend run dev",
    "dev:backend": "yarn workspace @repo/backend run start:dev",
    "build": "yarn workspaces foreach --all --topological-dev --include '@repo/backend' --include '@repo/frontend' run build",
    "start": "yarn workspaces foreach --all --parallel --interlaced --include '@repo/backend' --include '@repo/frontend' run start",
    "lint": "yarn workspaces foreach --all --parallel --interlaced run lint",
    "test": "yarn workspaces foreach --all --parallel --interlaced run test"
  }
}
